rules_version = '2';

// Kubera Firestore security rules.
// Replace every `you@example.com` below with YOUR Google account (the one you
// sign into /admin with) — it must match NEXT_PUBLIC_ADMIN_EMAILS. Tip: a
// find-and-replace across this file is the fastest way.
// Deploy: Firebase Console → Firestore Database → Rules → paste → Publish
//   (or: firebase deploy --only firestore:rules).

service cloud.firestore {
  match /databases/{database}/documents {

    // Waitlist signups: anyone may add their email; only the admin can read.
    match /waitlist/{doc} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() < 200;
      allow read:   if request.auth != null
                    && request.auth.token.email == 'you@example.com';
      allow update, delete: if false;
    }

    // Customer orders: anyone may place a shaped order; only the admin reads
    // and updates status. No client deletes.
    match /orders/{doc} {
      allow create: if request.resource.data.keys().hasAll(['type','lines','total','name','phone','status'])
                    && request.resource.data.type in ['dinein','pickup','delivery']
                    // staff surfaces (shop account) create straight-to-kitchen
                    // 'new'; customer DINE-IN starts 'pending' — the waiter
                    // must approve before the kitchen sees it. Customer
                    // pickup/delivery go straight to 'new'.
                    && ((request.auth != null && request.auth.token.email == 'you@example.com'
                         && request.resource.data.status in ['new', 'pending'])
                        || (request.resource.data.type == 'dinein' && request.resource.data.status == 'pending')
                        || (request.resource.data.type != 'dinein' && request.resource.data.status == 'new'))
                    && request.resource.data.lines is list
                    && request.resource.data.lines.size() > 0
                    && request.resource.data.lines.size() <= 40
                    && request.resource.data.total is number
                    && request.resource.data.total >= 0
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 80
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() <= 20
                    // ANTI-TABLE-SPOOF: a dine-in order must carry the secret
                    // key baked into that table's QR (get() validates it
                    // server-side). Staff/cashier (shop account) are exempt.
                    // Pickup/delivery need no key.
                    && (request.resource.data.type != 'dinein'
                        || (request.auth != null && request.auth.token.email == 'you@example.com')
                        || (request.resource.data.tableKey is string
                            && exists(/databases/$(database)/documents/table_codes/$(request.resource.data.table))
                            && get(/databases/$(database)/documents/table_codes/$(request.resource.data.table)).data.code == request.resource.data.tableKey));
      // Admin reads/updates everything; customers read their own orders.
      allow read: if request.auth != null
                    && (request.auth.token.email == 'you@example.com'
                        || resource.data.uid == request.auth.uid);
      // Customers may ONLY flip their payment claim ("I've paid via UPI") —
      // nothing else. Verification stays manual until the bank API lands.
      allow update: if (request.auth != null
                        && request.auth.token.email == 'you@example.com')
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['payment'])
                        && request.resource.data.payment.state == 'claimed');
      allow delete: if false;
    }

    // User profiles — auto-links email ↔ phone ↔ member QR. Owner + admin.
    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || request.auth.token.email == 'you@example.com');
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Menu overrides & custom items — site reads; admin writes.
    match /menu_admin/{doc} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }

    // Offers / featured banners — site reads; admin writes.
    match /offers/{doc} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }

    // Customer feedback — anyone may submit; admin reads.
    match /feedback/{doc} {
      allow create: if request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() < 2000;
      allow read: if request.auth != null
                  && request.auth.token.email == 'you@example.com';
      allow update, delete: if false;
    }

    // Site settings (ordering on/off, banner text) — site reads; admin writes.
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }

    // Table sittings (floor view) — seat→leave log per table. Written only
    // from staff/admin surfaces, which ride the shop Google account.
    match /table_sessions/{doc} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }

    // Per-table secret codes baked into each table's QR. NOT public-read
    // (a hacker mustn't enumerate them); rules get()/exists() still validate
    // dine-in orders server-side. Admin reads/writes via the QR generator.
    match /table_codes/{t} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == 'you@example.com';
    }

    // Inventory + vendor book — staff surfaces (shop account) write,
    // PIN identity enforced in-app via the operator gate + item logs.
    match /inventory/{doc} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }
    // Ops events — wastage (and future exception kinds) for the owner's
    // exceptions board. Staff tablets ride the shop account.
    match /ops_events/{doc} {
      allow read: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
      // append-only financial feed: shape-checked, never edited or deleted
      allow create: if request.auth != null
                   && request.auth.token.email == 'you@example.com'
                   && request.resource.data.kind is string
                   && request.resource.data.amount is number
                   && request.resource.data.amount >= 0
                   && request.resource.data.by is string
                   && request.resource.data.atMs is number;
      allow update, delete: if false;
    }
    // Digital collectibles — twins of printed stickers, granted by Sticker
    // Studio (shop account). Guests read their own via uid/member/phone match.
    match /collectibles/{doc} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }
    // Purchases ledger — vendor bills, PAID vs DUE tracking (accounts only;
    // actual payments happen outside the system).
    match /purchases/{doc} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }
    match /vendors/{doc} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }

    // Tablet presence mesh — label + page + heartbeat timestamp only.
    match /device_sessions/{doc} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['label','page','lastSeen'])
                   && request.resource.data.label is string
                   && request.resource.data.label.size() <= 60;
    }

    // Staff roster — names/roles + hashed PINs only. Portal reads; admin writes.
    match /staff_members/{doc} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }

    // Attendance — created/closed from the tablet portal (PIN-gated in app).
    // Integrity check: the staffId must be a real roster member and the name
    // must match that doc — blocks mismatched id↔name records. (PIN verify is
    // client-side / attendance-grade by design.)
    match /attendance/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['staffId','name','date'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 80
                    && exists(/databases/$(database)/documents/staff_members/$(request.resource.data.staffId))
                    && get(/databases/$(database)/documents/staff_members/$(request.resource.data.staffId)).data.name == request.resource.data.name;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['outAt']);
      allow delete: if request.auth != null
                    && request.auth.token.email == 'you@example.com';
    }

    // Digital shift forms (FRM-01/03/07/08) — tablet creates; admin deletes.
    // When the submission carries a staffId (operator-signed), it must point
    // at a real roster member whose name matches staffName.
    match /form_submissions/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['form','date','payload'])
                    && request.resource.data.form in ['FRM-01','FRM-03','FRM-07','FRM-08']
                    && request.resource.data.date is string
                    && (!('staffId' in request.resource.data)
                        || (exists(/databases/$(database)/documents/staff_members/$(request.resource.data.staffId))
                            && get(/databases/$(database)/documents/staff_members/$(request.resource.data.staffId)).data.name == request.resource.data.staffName));
      // submissions stay immutable EXCEPT read-acknowledgements (handover ✓)
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acks']);
      allow delete: if request.auth != null
                    && request.auth.token.email == 'you@example.com';
    }

    // Coupons: clients fetch a code by exact id only (no listing). Admin writes
    // via console or with the admin account.
    match /coupons/{code} {
      allow get: if true;
      allow list: if false;
      allow write: if request.auth != null
                   && request.auth.token.email == 'you@example.com';
    }

    // ShopSense edge events: created by the ingest API (gated by SHOPSENSE_INGEST_TOKEN),
    // readable only by the admin.
    match /shopsense_events/{doc} {
      allow create: if true;
      allow read:   if request.auth != null
                    && request.auth.token.email == 'you@example.com';
      allow update, delete: if false;
    }

    // Everything else: locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
