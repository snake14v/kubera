# Copy this file to `.env.local` and fill in real values.
# In production, add the same keys as environment variables on your host.
# Everything here is OPTIONAL — the app builds & runs with demo defaults.

# ─────────────────────────────────────────────────────────────
# YOUR BUSINESS — shown on the storefront, receipts, UPI payee & SEO.
# Sensible demo defaults apply if blank. No code edits needed to rebrand.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BUSINESS_NAME=Demo Café
NEXT_PUBLIC_BUSINESS_SHORT=Demo
NEXT_PUBLIC_BUSINESS_TAGLINE=Great coffee, fairly priced.
NEXT_PUBLIC_BUSINESS_EMAIL=hello@example.com
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_WHATSAPP=
NEXT_PUBLIC_BUSINESS_ADDR1=123 Demo Street
NEXT_PUBLIC_BUSINESS_ADDR2=Your City 000000
NEXT_PUBLIC_BUSINESS_INSTAGRAM=
NEXT_PUBLIC_CURRENCY=₹
NEXT_PUBLIC_OPENING=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Project links shown in footer/credits (override if you fork the project).
NEXT_PUBLIC_REPO_URL=https://github.com/oorulogix/kubera
NEXT_PUBLIC_PROJECT_URL=https://kubera.dev
NEXT_PUBLIC_AUTHOR_URL=https://oorulogix.com

# ─────────────────────────────────────────────────────────────
# Resend — waitlist + contact email delivery (optional).
# Sign up free at https://resend.com and create an API key.
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
WAITLIST_TO=you@example.com
WAITLIST_FROM=Waitlist <waitlist@example.com>

# ─────────────────────────────────────────────────────────────
# Firebase — Google sign-in (admin) + Firestore (data store).
# Firebase Console → Project settings → Your apps → Web app → SDK config.
# These NEXT_PUBLIC_ values are public by design; security is enforced by
# Firestore rules + the Auth authorized-domains list. Leave blank to run the
# app in "no backend" mode (storefront renders; admin/data features off).
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Comma-separated Google emails allowed into /admin (also set in firestore.rules).
NEXT_PUBLIC_ADMIN_EMAILS=you@example.com

# ─────────────────────────────────────────────────────────────
# Loyverse — optional loyalty/rewards (the /rewards portal can read points).
# Loyverse → Settings → Access tokens → create a token. Server-only secret.
# ─────────────────────────────────────────────────────────────
LOYVERSE_TOKEN=

# ─────────────────────────────────────────────────────────────
# ShopSense — bearer token the hardware sensor nodes send to
# /api/shopsense/ingest. Generate any long random string; burn the same value
# into the node firmware. If blank, ingest accepts unauthenticated posts (dev).
# ─────────────────────────────────────────────────────────────
SHOPSENSE_INGEST_TOKEN=
